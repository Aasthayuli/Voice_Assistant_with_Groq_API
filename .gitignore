# ============================================
# Voice Assistant Project - .gitignore
# ============================================

# ============================================
# ENVIRONMENT & SECRETS
# ============================================
.env
.env.local
.env.*.local
*.key
secrets/

# ============================================
# PYTHON / BACKEND
# ============================================

# Virtual Environment
venv/
env/
ENV/
.venv
*.pyc
__pycache__/
*.py[cod]
*$py.class

# Flask
instance/
.webassets-cache

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# ============================================
# AUDIO FILES (Important!)
# ============================================
backend/static/audio/uploads/*.webm
backend/static/audio/uploads/*.wav
backend/static/audio/uploads/*.mp3
backend/static/audio/uploads/*.m4a
backend/static/audio/uploads/*.ogg

backend/static/audio/outputs/*.mp3
backend/static/audio/outputs/*.wav

# Keep folder structure but ignore contents
backend/static/audio/uploads/*
backend/static/audio/outputs/*
!backend/static/audio/uploads/.gitkeep
!backend/static/audio/outputs/.gitkeep

# ============================================
# NODE / FRONTEND
# ============================================

# Dependencies
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Production builds
frontend/dist/
frontend/build/

# Vite
.vite/
frontend/.vite/

# Environment
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# LOGS
# ============================================
*.log
logs/
*.log.*

# ============================================
# SYSTEM FILES
# ============================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
*.bak
*.swp
temp/
tmp/

# ============================================
# DATABASE
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# MISC
# ============================================
.cache/
*.pid
*.seed
*.pid.lock

#===========================================
project_structure.md